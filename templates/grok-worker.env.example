# Grok BYOK credentials + custom-model config for the grok-impl agent.
# Copy to ~/.grok/grok-worker.env, fill in your values, then: chmod 600 ~/.grok/grok-worker.env
# NEVER commit real values. The .example is safe; the real one is gitignored.

# Your xAI / proxy API key (sent as `Authorization: Bearer` to the endpoint below).
export XAI_API_KEY="sk-REPLACE_WITH_YOUR_KEY"

# Inference endpoint. MUST end in /v1 (grok fetches the model list from {base}/models).
# xAI direct = https://api.x.ai/v1, or your own OpenAI-compatible proxy base URL.
export GROK_MODELS_BASE_URL="https://your-endpoint.example.com/v1"

# The model grok-impl runs. STRONGLY PREFER a CUSTOM model id you define in ~/.grok/config.toml
# (see below) — NOT a built-in id like `grok-4.5`.
#   WHY: a built-in id routes through xAI's own auth (OIDC). If grok has ANY cached OIDC login
#   (even an EXPIRED one), it uses that instead of your key and can HANG on token refresh
#   (not just return 401). A custom model with an explicit base_url + api_key/env_key is a plain
#   OpenAI-compatible path that NEVER touches OIDC — the robust BYOK route.
export GROK_IMPL_MODEL="byok-grok"

# ── Companion config: ~/.grok/config.toml ───────────────────────────────────────
# Define the custom model referenced above. `env_key` reads XAI_API_KEY from this env file at
# runtime (or hardcode `api_key = "..."`). `model` is the real id your endpoint serves.
#
#   [model.byok-grok]
#   model    = "grok-4.5"                        # the id your endpoint actually serves
#   base_url = "https://your-endpoint.example.com/v1"
#   env_key  = "XAI_API_KEY"
#   name     = "Grok (BYOK)"
#
#   # optional — make interactive grok use it too:
#   [models]
#   default = "byok-grok"
#
# `grok logout` is a weaker alternative (clears the cached OIDC login) but is FRAGILE — a later
# `grok login` silently reintroduces the hang. The custom-model route above needs no logout.
#
# Windows (native PowerShell) can't source this file — set vars in your session/$PROFILE:
#   $env:XAI_API_KEY="sk-..."; $env:GROK_MODELS_BASE_URL="https://your-endpoint/v1"; $env:GROK_IMPL_MODEL="byok-grok"
# WSL2 / Git Bash: `. ~/.grok/grok-worker.env` works as-is. See cc-engines/cross-platform.md.
