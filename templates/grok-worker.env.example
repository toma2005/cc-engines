# Grok BYOK credentials for the grok-impl agent.
# Copy to ~/.grok/grok-worker.env, fill in your own values, then: chmod 600 ~/.grok/grok-worker.env
# NEVER commit this file with real values. The .example is safe; the real one is gitignored.

# Your xAI / proxy API key.
export XAI_API_KEY="sk-REPLACE_WITH_YOUR_KEY"

# Inference endpoint. MUST end in /v1 (grok fetches the model list from {base}/models).
# Use api.x.ai/v1 for xAI directly, or your own OpenAI-compatible proxy base URL.
export GROK_MODELS_BASE_URL="https://your-endpoint.example.com/v1"

# The model id the grok-impl agent should use (see: grok models).
export GROK_IMPL_MODEL="REPLACE_WITH_MODEL_ID"

# Reminder: run `grok logout` once so the API key is used instead of a cached OIDC login.
#
# Windows (native PowerShell) can't source this file — set the vars in your session/$PROFILE instead:
#   $env:XAI_API_KEY = "sk-..."; $env:GROK_MODELS_BASE_URL = "https://your-endpoint/v1"; $env:GROK_IMPL_MODEL = "<model>"
# Under WSL2 / Git Bash this file works as-is (`. ~/.grok/grok-worker.env`). See cc-engines/cross-platform.md.
